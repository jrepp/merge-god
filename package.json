{
  "name": "merge-god",
  "version": "0.1.0",
  "type": "module",
  "description": "Automated PR processing and merging system using the pi coding agent",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "merge-god": "bin/merge-god.js",
    "merge-god-dashboard": "bin/merge-god-dashboard.js",
    "merge-god-pr-loop": "bin/merge-god-pr-loop.js"
  },
  "files": [
    "*.ts",
    "agents/",
    "bin/",
    "config.example.yaml",
    "config.merge-god-self-test.example.yaml",
    "docs/",
    "merge-rules.yaml",
    "merge_god/",
    "packages/github-sync/src/",
    "packages/github-sync/package.json",
    "packages/workflow-ir-core/src/",
    "packages/workflow-ir-core/package.json",
    "pi/",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "ci": "npm run typecheck && npm test && npm run test:coverage:check && npm run markdownlint",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts packages/github-sync/tests/*.test.ts packages/workflow-ir-core/tests/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-include='*.ts' --test-coverage-include='packages/**/src/*.ts' --test-coverage-exclude='tests/**' --test-coverage-exclude='site/**' tests/*.test.ts packages/github-sync/tests/*.test.ts packages/workflow-ir-core/tests/*.test.ts",
    "test:coverage:check": "npm run test:coverage -- --test-coverage-lines=70 --test-coverage-branches=55 --test-coverage-functions=65",
    "dashboard": "tsx dashboard.ts",
    "scan": "tsx pr-loop.ts",
    "agent": "tsx merge-god.ts",
    "validate": "tsx merge_god/validate.ts",
    "status": "tsx merge-god.ts status",
    "prompt:eval": "PROMPTFOO_CONFIG_DIR=.promptfoo PROMPTFOO_DISABLE_TELEMETRY=true promptfoo eval -c evals/promptfoo/promptfooconfig.yaml",
    "prompt:optimize": "PROMPTFOO_CONFIG_DIR=.promptfoo PROMPTFOO_DISABLE_TELEMETRY=true promptfoo optimize -c evals/promptfoo/pr-agent-optimization.yaml",
    "prompt:view": "PROMPTFOO_CONFIG_DIR=.promptfoo PROMPTFOO_DISABLE_TELEMETRY=true promptfoo view",
    "lint": "npm run markdownlint",
    "markdownlint": "markdownlint --config .markdownlintrc --ignore node_modules --ignore 'node_modules/**' --ignore .venv --ignore site '**/*.md'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@merge-god/github-sync": "0.1.0",
    "@merge-god/workflow-ir-core": "0.1.0",
    "@octokit/rest": "^21.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "chalk": "^5.3.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "systeminformation": "^5.22.0",
    "tsx": "^4.19.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "markdownlint-cli": "^0.49.0",
    "promptfoo": "^0.121.17",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "promptfoo": {
      "@opentelemetry/core": "2.9.0",
      "@opentelemetry/resources": "2.9.0",
      "@opentelemetry/sdk-trace-base": "2.9.0",
      "@opentelemetry/sdk-trace-node": "2.9.0"
    }
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jrepp/merge-god.git"
  },
  "keywords": [],
  "author": "",
  "bugs": {
    "url": "https://github.com/jrepp/merge-god/issues"
  },
  "homepage": "https://github.com/jrepp/merge-god#readme"
}
