{
  "name": "merge-god",
  "version": "0.1.0",
  "type": "module",
  "description": "Automated PR processing and merging system using the Claude Agent SDK + pi coding agent",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "merge-god": "bin/merge-god.js",
    "merge-god-dashboard": "bin/merge-god-dashboard.js",
    "merge-god-pr-loop": "bin/merge-god-pr-loop.js"
  },
  "files": [
    "*.ts",
    "agents/",
    "bin/",
    "config.example.yaml",
    "docs/",
    "merge_god/",
    "packages/github-sync/src/",
    "packages/github-sync/package.json",
    "pi/",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "ci": "tsc --noEmit && node --import tsx --test tests/*.test.ts packages/github-sync/tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts packages/github-sync/tests/*.test.ts",
    "dashboard": "tsx dashboard.ts",
    "scan": "tsx pr-loop.ts",
    "agent": "tsx merge-god.ts",
    "validate": "tsx merge_god/validate.ts",
    "status": "tsx merge-god.ts status",
    "lint": "markdownlint --config .markdownlintrc .",
    "markdownlint": "markdownlint --config .markdownlintrc ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@merge-god/github-sync": "0.1.0",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.3.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "systeminformation": "^5.22.0",
    "tsx": "^4.19.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0",
    "markdownlint-cli": "^0.43.0"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jrepp/merge-god.git"
  },
  "keywords": [],
  "author": "",
  "bugs": {
    "url": "https://github.com/jrepp/merge-god/issues"
  },
  "homepage": "https://github.com/jrepp/merge-god#readme"
}
