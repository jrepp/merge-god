---
import Logo from "./Logo.astro";
import { base } from "../lib/site";

const repoUrl = "https://github.com/jrepp/merge-god";

// Current path (without trailing slash) for active-link highlighting.
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => {
  const full = (base + href.replace(/^\//, "")).replace(/\/+$/, "") || "/";
  return path === full || (href !== "/" && path.startsWith(full));
};

const nav = [
  { href: "/docs/", label: "Docs" },
  { href: "/design/", label: "Design" },
  { href: "#features", label: "Features" },
  { href: "#quickstart", label: "Quickstart" },
];
---

<header class="site-header">
  <div class="container nav">
    <a href={`${base}`} class="brand" aria-label="merge-god home">
      <Logo size={30} />
      <span class="brand-name">merge<span class="gradient-text">-god</span></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href.startsWith("#") ? item.href : `${base}${item.href.replace(/^\//, "")}`}
          class:list={["nav-link", { active: !item.href.startsWith("#") && isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="nav-actions">
      <a href={repoUrl} class="nav-link gh" target="_blank" rel="noopener" aria-label="GitHub repository">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1-.02-1.96-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.02 11.02 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.35.78 1.05.78 2.12 0 1.53-.01 2.76-.01 3.14 0 .31.21.68.8.56A11.51 11.51 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
          ></path>
        </svg>
        <span>GitHub</span>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(11, 12, 20, 0.72);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    gap: var(--space-5);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
  }
  .brand:hover {
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-pill);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }
  .nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface);
  }
  .nav-link.active {
    color: var(--color-text);
    background: var(--color-surface);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .nav-link.gh {
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface);
  }
  .nav-link.gh:hover {
    border-color: var(--color-border);
  }

  @media (max-width: 720px) {
    .nav-links {
      display: none;
    }
  }
</style>
